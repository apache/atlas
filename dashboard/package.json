{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-native-deps.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 200",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "prebuild": "cd src/views/Lineage/atlas-lineage && (npm ci 2>/dev/null || npm install) && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:governance": "RUN_DEPENDENCY_GOVERNANCE=1 jest --testPathPattern=governance --runInBand",
    "build:with-governance": "npm run test:governance && npm run build",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:verbose": "jest --verbose",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run"
  },
  "dependencies": {
