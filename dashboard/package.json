{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-native-deps.mjs",
    "dev": "vite",
    "build": "vite build",
    "build:lineage": "node scripts/ensure-lineage-build.mjs",
    "build:legacy": "npm run build:lineage && vite build",
    "build:check": "tsc --noEmit -p tsconfig.build.json && vite build",
    "lint": "eslint 'src/**/*.{ts,tsx}' vite.config.ts --report-unused-disable-directives --max-warnings 200",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:governance": "RUN_DEPENDENCY_GOVERNANCE=1 jest --testPathPattern=governance --runInBand",
    "build:with-governance": "npm run test:governance && npm run build",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:verbose": "jest --verbose",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run"
  },
