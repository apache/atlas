{
  "compilerOptions": {
    "target": "ES2018",
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2018", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": false,
    "baseUrl": "./src",
    "paths": {
      "@components/*": ["components/*"],
      "@api/*": ["api/*"],
      "@utils/*": ["utils/*"],
      "@styles/*": ["styles/*"],
      "@services/*": ["services/*"],
      "@views/*": ["views/*"],
      "@hooks/*": ["hooks/*"],
      "@models/*": ["models/*"],
      "@contexts/*": ["contexts/*"],
      "@redux/*": ["redux/*"]
    }
  },
  "include": [
    "src/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}